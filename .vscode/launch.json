    "version": "0.2.0",
    "configurations": [

       
        {
            "name": "3000",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node-terminal",
            "name": "FE: dev",
            "request": "launch",
            "command": "yarn dev",
            "cwd": "${workspaceFolder}/apps/console",
        },
        {
            "type": "node-terminal",
            "name": "BE: dev",
            "request": "launch",
            "command": "yarn dev",
            "cwd": "${workspaceFolder}/apps/backend",
        }
    ]
}