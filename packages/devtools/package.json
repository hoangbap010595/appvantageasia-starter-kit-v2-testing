{
  "name": "@appvantageasia/devtools",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "bin": {
    "devtools-build-backend": "./build/commands/build-backend.js",
    "devtools-build-lib": "./build/commands/build-lib.js",
    "devtools-run-backend": "./build/commands/run-backend.js"
  },
  "scripts": {
    "clean": "yarn rimraf -rf build ./tsconfig.tsbuildinfo ./typescript-report.json",
    "build": "tsc ./src/**/*.ts --skipLibCheck --esModuleInterop --declaration --outDir ./build --module nodenext",
    "build:watch": "yarn build --watch",
    "lint": "eslint",
    "lint:types": "yarn node ./build/github-actions/typescript-checker.js",
    "postinstall": "yarn build",
    "lint:commits": "node ./build/commands/lint-commits.js"
  },
  "devDependencies": {
    "@appvantageasia/eslint-config": "*",
    "@appvantageasia/tsconfig": "*",
    "@sentry/esbuild-plugin": "^4.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.1.0",
    "@types/semver": "^7.7.0",
    "@types/source-map-support": "^0.5.10",
    "@types/tail": "^2.2.3",
    "@types/wait-on": "^5.3.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "@aws-sdk/client-s3": "^3.850.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@luckycatfactory/esbuild-graphql-loader": "^3.8.1",
    "@octokit/rest": "^22.0.0",
    "@sentry/cli": "^2.50.2",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "dotenv": "^17.2.0",
    "dotenv-expand": "^12.0.2",
    "esbuild": "^0.25.8",
    "esbuild-plugin-copy-watch": "^2.3.1",
    "execa": "^9.6.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.3",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "mime-types": "^3.0.1",
    "nanoid": "^5.1.5",
    "node-fetch": "^3.3.2",
    "parse-duration": "^2.1.4",
    "rimraf": "^6.0.1",
    "semver": "^7.7.2",
    "source-map-support": "^0.5.21",
    "tail": "^2.2.6",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3"
  }
}
